# === API Keys ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
GEMINI_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# === Custom Ollama Endpoint Config ===
CUSTOM_OPENAI_API_BASE=
CUSTOM_OPENAI_API_KEY=

# === LLM Model Configuration ===
# All models are swappable via env. Supported providers and latest model IDs:
#   openai:        gpt-5.5, gpt-5.4, gpt-5.4-mini, gpt-5.4-nano
#   deepseek:      deepseek-v4-pro, deepseek-v4-flash
#   gemini:        gemini-3.5-flash, gemini-3.1-flash-lite
#   anthropic:     claude-opus-4-8, claude-sonnet-4-6, claude-haiku-4-5
#   custom_openai: any model via CUSTOM_OPENAI_API_BASE (e.g., OpenWebUI, Ollama)
#
# Defaults (if not set): extractor/synthesizer = openai/gpt-5.4-nano, judge = deepseek/deepseek-v4-pro

PROVIDER_EXTRACTION=deepseek
EXTRACTOR_MODEL=deepseek-v4-flash
PROVIDER_SYNTHESIS=deepseek
SYNTHESIZER_MODEL=deepseek-v4-flash

JUDGE_PROVIDER=gemini
JUDGE_MODEL=gemini-3.1-flash-lite

# === LLM Parameters ===
TEMPERATURE=0.2
MAX_RETRIES=3

# === Performance ===
MAX_PARALLEL_EXTRACTIONS=5

# === Agent-specific temperatures ===
LIBRARIAN_TEMPERATURE=0.3
LIBRARIAN_SUMMARY_TEMPERATURE=0.5
FACT_CHECKER_TEMPERATURE=0.3
CRITIC_TEMPERATURE=0.6

# === Token Limits ===
# Per-role overrides (optional — litellm auto-detects for known models)
# MAX_TOKENS_EXTRACTION=16384
# MAX_TOKENS_SYNTHESIS=16384
# MAX_TOKENS_JUDGE=32768

# Fallback when litellm can't detect the model's max output tokens
TOKEN_LIMIT_DEFAULT=16384

# === Timeouts ===
LLM_TIMEOUT=300
API_TIMEOUT=30

# === Content limits ===
MAX_CONTENT_TOKENS=100000

# === Rate limiting ===
ARXIV_MIN_REQUEST_INTERVAL=3.0
LIBRARIAN_PRE_SEARCH_DELAY=1.0
LIBRARIAN_RETRY_DELAY=2.0

# === Batch processing ===
BATCH_MAX_WORKERS=4

# === Cost thresholds ===
COST_WARNING_PER_PAPER=1.0

# === JSON retries ===
CRITIC_MAX_JSON_RETRIES=3
FACT_CHECKER_MAX_RETRIES=2

# === Literature Grounding ===
# Priority: --no-literature CLI flag > LITERATURE_GROUNDING_ENABLED env > literature_sources.yaml
LITERATURE_GROUNDING_ENABLED=false
